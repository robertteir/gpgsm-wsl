#!/usr/bin/env bash
set -euo pipefail

GPGSM_WIN='/mnt/c/Program Files/GnuPG/bin/gpgsm.exe'
GPG_WIN='/mnt/c/Program Files/GnuPG/bin/gpg.exe'

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

# Convert Linux absolute paths to Windows paths.
to_win_path() {
  case "$1" in
    /*) wslpath -w "$1" ;;
    *)  printf '%s\n' "$1" ;;
  esac
}

args=()
stdin_to_file=false
stdin_file="$tmpdir/stdin-data"

while (($#)); do
  case "$1" in
    -)
      # Git passes "-" to mean "read signed data from stdin".
      stdin_to_file=true
      shift
      ;;
    *)
      args+=("$(to_win_path "$1")")
      shift
      ;;
  esac
done

if $stdin_to_file; then
  cat > "$stdin_file"
  args+=("$(wslpath -w "$stdin_file")")
fi

# Wake scdaemon/PCSC before gpgsm. Avoids a spurious "insert card" on the first
# sign after another client (e.g. SSH with PKCS#11) released the reader.
# stdin must be /dev/null: Git pipes the commit payload on our stdin for signing;
# gpg must not read it or gpgsm would sign empty/wrong data.
"$GPG_WIN" --card-status </dev/null >/dev/null 2>&1 || true

exec "$GPGSM_WIN" "${args[@]}"
